local function teleportToPart(partName)
	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if not hrp then return false end
	for _, obj in ipairs(workspace:GetDescendants()) do
		if string.lower(obj.Name) == string.lower(partName) then
			if obj:IsA("BasePart") then
				hrp.CFrame = obj.CFrame + Vector3.new(0, 3, 0)
				return true
			elseif obj:IsA("Model") and obj.PrimaryPart then
				hrp.CFrame = obj.PrimaryPart.CFrame + Vector3.new(0, 3, 0)
				return true
			end
		end
	end
	return false
end

local function refreshList()
	for _, child in ipairs(scrollFrame:GetChildren()) do
		if child:IsA("Frame") or child:IsA("TextLabel") then
			child:Destroy()
		end
	end
	
	local groups = {}
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") or (obj:IsA("Model") and obj.PrimaryPart) then
			local firstChar = string.upper(string.sub(obj.Name, 1, 1))
			if string.match(firstChar, "%a") then
				groups[firstChar] = groups[firstChar] or {}
				if not table.find(groups[firstChar], obj.Name) then
					table.insert(groups[firstChar], obj.Name)
				end
			end
		end
	end
	
	for _, names in pairs(groups) do table.sort(names) end
	local sortedLetters = {}
	for letter in pairs(groups) do table.insert(sortedLetters, letter) end
	table.sort(sortedLetters)
	
	local mainLayoutOrder = 1
	for _, letter in ipairs(sortedLetters) do
		local header = Instance.new("TextLabel", scrollFrame)
		header.Size = UDim2.new(1, -10, 0, 20)
		header.BackgroundTransparency = 1
		header.TextColor3 = Color3.fromRGB(255, 255, 0)
		header.Font = Enum.Font.GothamBold
		header.TextSize = 14
		header.TextXAlignment = Enum.TextXAlignment.Left
		header.Text = letter
		header.LayoutOrder = mainLayoutOrder
		header.ZIndex = 1001
		mainLayoutOrder = mainLayoutOrder + 1
		
		for _, partName in ipairs(groups[letter]) do
			local row = Instance.new("Frame", scrollFrame)
			row.Size = UDim2.new(1, -10, 0, 22)
			row.BackgroundTransparency = 1
			row.LayoutOrder = mainLayoutOrder
			row.ZIndex = 1001
			mainLayoutOrder = mainLayoutOrder + 1
			
			local nameLabel = Instance.new("TextLabel", row)
			nameLabel.Size = UDim2.new(1, -40, 1, 0)
			nameLabel.BackgroundTransparency = 1
			nameLabel.TextColor3 = Color3.new(1, 1, 1)
			nameLabel.Font = Enum.Font.Gotham
			nameLabel.TextSize = 13
			nameLabel.TextXAlignment = Enum.TextXAlignment.Left
			nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
			nameLabel.Text = partName
			nameLabel.ZIndex = 1002
			
			local tpBtn = Instance.new("TextButton", row)
			tpBtn.Size = UDim2.new(0, 35, 0, 20)
			tpBtn.Position = UDim2.new(1, -35, 0, 1)
			tpBtn.Text = "TP"
			tpBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
			tpBtn.TextColor3 = Color3.new(1,1,1)
			tpBtn.Font = Enum.Font.GothamBold
			tpBtn.TextSize = 12
			tpBtn.ZIndex = 1002
			Instance.new("UICorner", tpBtn).CornerRadius = UDim.new(0, 4)
			
			tpBtn.MouseButton1Click:Connect(function()
				local success = teleportToPart(partName)
				tpBtn.Text = success and "✓" or "X"
				tpBtn.BackgroundColor3 = success and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
				task.wait(0.5)
				tpBtn.Text = "TP"
				tpBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
			end)
		end
	end
end

